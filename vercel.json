      "destination": "https://www.dmphysi0.com/sustiqnia/head-slepoochie.html",
      "permanent": true
    },
    {
      "source": "/neck-degeneracia.html",
      "destination": "https://www.dmphysi0.com/sustiqnia/neck-degeneracia.html",
      "permanent": true
    },
    {
      "source": "/neck-diskova.html",
      "destination": "https://www.dmphysi0.com/sustiqnia/neck-diskova.html",
      "permanent": true
    },
    {
      "source": "/neck-kamshichen.html",
      "destination": "https://www.dmphysi0.com/sustiqnia/neck-kamshichen.html",
      "permanent": true
    },
    {
      "source": "/neck-muscle.html",
