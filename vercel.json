      "permanent": true
    },
    {
      "source": "/neck-radiculupatia.html",
      "destination": "https://www.dmphysi0.com/sustiqnia/neck-radiculupatia.html",
      "permanent": true
    },
    {
      "source": "/neck-shipove.html",
      "destination": "https://www.dmphysi0.com/sustiqnia/neck-shipove.html",
      "permanent": true
    },
    {
      "source": "/procedures/masage-vendusa.html",
      "destination": "https://www.dmphysi0.com/procedures/massage-vendusa.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/book",
      "destination": "/book.html"
    },
    {
      "source": "/api/availability",
      "destination": "https://book.dmphysi0.com/api/availability"
    },
    {
      "source": "/api/book",
      "destination": "https://book.dmphysi0.com/api/book"
    },
    {
      "source": "/pngs/:path*",
      "destination": "https://pngs-worker.volter1996.workers.dev/pngs/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(css|js|woff2|woff|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|avif|gif|mp4|webm)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
